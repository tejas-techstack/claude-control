# claude-control — keep the repo to source only
__pycache__/
*.pyc
.crawl/               # local firecrawl output
external/             # cloned external skill repos (fetched at runtime, never committed)
REPO_MAP.md           # generated by tools/repo_map.py
CONTEXT_PACK.md       # generated by tools/context_pack.py
.graphify.json
setup.log             # written by /setup
.sandbox/             # written by /isolate
.DS_Store
